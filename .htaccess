Options -Indexes
DirectoryIndex index.php

<IfModule mod_env.c>
    SetEnv APP_ENV prod
    SetEnv APP_DEBUG 0
    SetEnv APP_HTTP_CACHE 0
    SetEnv DEFAULT_URI https://merouan.meha0348.odns.fr
    SetEnv XDEBUG_MODE off
</IfModule>

<IfModule mod_php.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 64M
    php_value max_file_uploads 20
</IfModule>

<IfModule mod_php8.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 64M
    php_value max_file_uploads 20
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Leave ACME challenges untouched.
    RewriteRule ^\.well-known/ - [L]

    # Keep the root front controller stable so Symfony can resolve the base path as /dashboard.
    RewriteRule ^index\.php(?:/.*)?$ - [L]

    # Canonicalize accidental /public URLs back to the site root.
    RewriteRule ^public/?$ ./ [R=302,L,NE]
    RewriteRule ^public/(.*)$ $1 [R=302,L,NE]

    # Serve files that are published under /public without exposing the whole folder in URLs.
    RewriteCond public/$1 -f [OR]
    RewriteCond public/$1 -d
    RewriteRule ^(.+)$ public/$1 [L]

    # Protect private Symfony files when the whole project is uploaded as web root.
    RewriteRule ^(?:bin|config|migrations|src|tests|translations|var|vendor|docs|scripts)(?:/|$) - [F,L,NC]
    RewriteRule ^(?:\.env(?:\..*)?|composer\.(?:json|lock)|symfony\.lock|phpunit(?:\.dist)?\.xml|CLAUDE\.md|implementation_plan\.md|walkthrough\.md)$ - [F,L,NC]

    RewriteCond %{HTTP:Authorization} ^(.*)
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%1]

    # Route application pages through the root front controller.
    RewriteRule ^ index.php [QSA,L]
</IfModule>

{% for item in items %}
    {% if item.children is not empty %}
        <div class="header-admin-item header-admin-item-parent{% if item.is_open %} is-open{% endif %}">
            <div class="header-admin-item-row">
                <a href="{{ item.url }}" class="header-admin-link{% if item.is_current %} is-active{% elseif item.is_open %} is-parent-active{% endif %}{% if item.icon_only %} header-admin-link-icon-only{% endif %}">
                    <span class="header-admin-link-icon">{{ item.icon_html|raw }}</span>
                    <span class="header-admin-link-label">{{ item.label }}</span>
                </a>
                <button type="button" class="header-admin-toggle" data-header-submenu-id="{{ item.submenu_id }}" aria-expanded="{% if item.is_open %}true{% else %}false{% endif %}" aria-controls="{{ item.submenu_id }}">
                    <span class="header-admin-toggle-chevron">▾</span>
                </button>
            </div>
            <div class="header-admin-submenu" id="{{ item.submenu_id }}">
                {{ include('_partials/menu/header_items.html.twig', {items: item.children}) }}
            </div>
        </div>
    {% else %}
        <a href="{{ item.url }}" class="header-admin-link{% if item.is_current %} is-active{% endif %}{% if item.icon_only %} header-admin-link-icon-only{% endif %}">
            <span class="header-admin-link-icon">{{ item.icon_html|raw }}</span>
            <span class="header-admin-link-label">{{ item.label }}</span>
        </a>
    {% endif %}
{% endfor %}

{% extends 'base.html.twig' %}

{% block title %}Services{% endblock %}

{% block body %}
{% set pageTitle = page_display_service.resolveNavigationLabel('admin_services', 'Services') %}

<div class="service-settings-page">
    <div class="service-settings-header">
        <div>
            <h1 class="page-title-heading">
                {{ page_display_service.renderNavigationIcon('admin_services', 'bi-diagram-3', 'bootstrap')|raw }}
                <span>{{ pageTitle }}</span>
            </h1>
            <p>Ajoutez, renommez, recolorez ou supprimez les services relies aux profils et a l'annuaire.</p>
        </div>
        <div class="service-settings-actions">
            <a href="{{ path('admin_parametrage') }}" class="btn btn-secondary">Retour aux parametres</a>
        </div>
    </div>

    {% for message in app.flashes('success') %}
        <div class="service-flash service-flash-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('danger') %}
        <div class="service-flash service-flash-danger">{{ message }}</div>
    {% endfor %}

    <div class="service-settings-grid">
        <section class="service-card">
            <h3>Ajouter un service</h3>
            <p>Cree un nouveau service qui sera ensuite disponible dans les profils utilisateurs et reutilise dans l'annuaire.</p>

            <form method="post" class="service-create-form">
                <input type="hidden" name="action" value="create_service">
                <div class="form-group">
                    <label for="service-name">Nom du service</label>
                    <input type="text" id="service-name" name="name" maxlength="255" placeholder="Ex. Support, RH, Production">
                </div>
                <div class="form-group">
                    <label for="service-color">Couleur</label>
                    <div class="service-color-row">
                        <input type="color" id="service-color" name="color" value="#6C757D" data-color-source="service-create-color">
                        <input type="text" value="#6C757D" class="service-color-code" data-color-target="service-create-color" maxlength="7" placeholder="#6C757D">
                    </div>
                </div>
                <button type="submit" class="btn btn-primary">Ajouter le service</button>
            </form>
        </section>

        <section class="service-card service-card-summary">
            <h3>Resume</h3>
            <div class="service-summary-metrics">
                <div class="service-metric">
                    <strong>{{ serviceCount }}</strong>
                    <span>service(s)</span>
                </div>
                <div class="service-metric">
                    <strong>{{ assignedUsers }}</strong>
                    <span>profil(s) rattache(s)</span>
                </div>
            </div>
            <p>Quand tu renommes un service ici, les profils qui l'utilisent sont mis a jour automatiquement. Si tu le supprimes, les profils rattaches passent sans service.</p>
        </section>
    </div>

    <section class="service-card">
        <div class="service-table-header">
            <div>
                <h3>Catalogue des services</h3>
                <p>Le nom et la couleur sont conserves dans la table <strong>services</strong>.</p>
            </div>
        </div>

        {% if services is empty %}
            <div class="service-empty-state">Aucun service n'est encore disponible.</div>
        {% else %}
            <div class="service-table-wrapper">
                <table class="service-table">
                    <thead>
                        <tr>
                            <th>Nom</th>
                            <th>Couleur</th>
                            <th>Apercu</th>
                            <th>Profils</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for service in services %}
                            <tr>
                                <td>
                                    <input type="text" name="name" value="{{ service.name }}" maxlength="255" form="update-service-{{ service.id }}">
                                </td>
                                <td>
                                    <div class="service-color-row">
                                        <input
                                            type="color"
                                            name="color"
                                            value="{{ service.color }}"
                                            form="update-service-{{ service.id }}"
                                            data-color-source="service-color-{{ service.id }}"
                                        >
                                        <input
                                            type="text"
                                            value="{{ service.color }}"
                                            class="service-color-code"
                                            form="update-service-{{ service.id }}"
                                            data-color-target="service-color-{{ service.id }}"
                                            maxlength="7"
                                        >
                                    </div>
                                </td>
                                <td>
                                    <span class="service-preview-badge" style="--service-color: {{ service.color }};">
                                        {{ service.name }}
                                    </span>
                                </td>
                                <td>
                                    <span class="service-usage">{{ service.usage_count }}</span>
                                </td>
                                <td>
                                    <div class="service-row-actions">
                                        <form id="update-service-{{ service.id }}" method="post">
                                            <input type="hidden" name="action" value="update_service">
                                            <input type="hidden" name="service_id" value="{{ service.id }}">
                                        </form>
                                        <button type="submit" form="update-service-{{ service.id }}" class="btn btn-primary btn-sm">Enregistrer</button>

                                        <form id="delete-service-{{ service.id }}" method="post">
                                            <input type="hidden" name="action" value="delete_service">
                                            <input type="hidden" name="service_id" value="{{ service.id }}">
                                        </form>
                                        <button
                                            type="submit"
                                            form="delete-service-{{ service.id }}"
                                            class="btn btn-danger btn-sm"
                                            onclick="return confirm('Supprimer le service {{ service.name|e('js') }} ? Les profils rattaches perdront cette affectation.');"
                                        >Supprimer</button>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </section>
</div>

<style>
    .service-settings-page {
        display: grid;
        gap: 1.5rem;
    }

    .service-settings-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .service-settings-header p {
        margin: 0.35rem 0 0;
        color: var(--text-muted);
        max-width: 760px;
    }

    .service-settings-grid {
        display: grid;
        grid-template-columns: minmax(320px, 420px) minmax(220px, 1fr);
        gap: 1rem;
    }

    .service-card {
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 1.25rem;
        background: var(--bg-primary);
        box-shadow: 0 2px 10px var(--shadow);
    }

    .service-card h3 {
        margin: 0 0 0.35rem;
    }

    .service-card p {
        margin: 0 0 1rem;
        color: var(--text-muted);
    }

    .service-flash {
        padding: 0.95rem 1rem;
        border-radius: 12px;
        border: 1px solid transparent;
    }

    .service-flash-success {
        border-color: rgba(34, 197, 94, 0.35);
        background: rgba(34, 197, 94, 0.08);
        color: var(--success, #16a34a);
    }

    .service-flash-danger {
        border-color: rgba(239, 68, 68, 0.35);
        background: rgba(239, 68, 68, 0.08);
        color: var(--danger, #dc2626);
    }

    .service-create-form {
        display: grid;
        gap: 0.9rem;
    }

    .service-color-row {
        display: grid;
        grid-template-columns: 64px minmax(120px, 1fr);
        gap: 0.75rem;
        align-items: center;
    }

    .service-color-row input[type="color"] {
        width: 64px;
        height: 46px;
        min-width: 64px;
        padding: 0.15rem;
    }

    .service-color-code {
        font-family: "Courier New", monospace;
        letter-spacing: 0.03em;
        text-transform: uppercase;
    }

    .service-card-summary {
        display: grid;
        align-content: start;
    }

    .service-summary-metrics {
        display: flex;
        flex-wrap: wrap;
        gap: 0.85rem;
        margin-bottom: 1rem;
    }

    .service-metric {
        min-width: 140px;
        padding: 1rem;
        border-radius: 14px;
        background: var(--bg-secondary);
        border: 1px solid var(--border);
        display: grid;
        gap: 0.25rem;
    }

    .service-metric strong {
        font-size: 1.6rem;
        line-height: 1;
    }

    .service-metric span {
        color: var(--text-muted);
        font-size: 0.92rem;
    }

    .service-table-header {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: flex-start;
        margin-bottom: 1rem;
    }

    .service-table-wrapper {
        overflow-x: auto;
    }

    .service-table {
        width: 100%;
        border-collapse: collapse;
    }

    .service-table th,
    .service-table td {
        padding: 0.85rem 0.75rem;
        border-bottom: 1px solid var(--border);
        vertical-align: middle;
    }

    .service-table th {
        text-align: left;
        color: var(--text-muted);
        font-size: 0.85rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
    }

    .service-preview-badge {
        display: inline-flex;
        align-items: center;
        padding: 0.45rem 0.75rem;
        border-radius: 999px;
        background: var(--service-color);
        color: #fff;
        font-weight: 600;
        min-width: 110px;
        justify-content: center;
    }

    .service-row-actions {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .service-usage {
        display: inline-flex;
        min-width: 36px;
        min-height: 36px;
        border-radius: 999px;
        align-items: center;
        justify-content: center;
        background: var(--bg-secondary);
        border: 1px solid var(--border);
        font-weight: 700;
    }

    .service-empty-state {
        padding: 1rem;
        border-radius: 12px;
        border: 1px dashed var(--border);
        color: var(--text-muted);
        background: var(--bg-secondary);
    }

    .btn-danger {
        background: #dc2626;
        color: #fff;
    }

    .btn-danger:hover {
        background: #b91c1c;
    }

    .btn-sm {
        padding: 0.55rem 0.85rem;
        font-size: 0.92rem;
    }

    @media (max-width: 920px) {
        .service-settings-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            function normalizeHexColor(value) {
                let color = String(value || '').trim().toUpperCase();
                if (color !== '' && color.charAt(0) !== '#') {
                    color = '#' + color;
                }

                return /^#[0-9A-F]{6}$/.test(color) ? color : '';
            }

            document.querySelectorAll('[data-color-source]').forEach(function (colorInput) {
                const key = colorInput.getAttribute('data-color-source') || '';
                if (!key) {
                    return;
                }

                const textInput = document.querySelector('[data-color-target="' + key + '"]');
                if (!textInput) {
                    return;
                }

                colorInput.addEventListener('input', function () {
                    textInput.value = String(colorInput.value || '').toUpperCase();
                });

                textInput.addEventListener('input', function () {
                    const normalized = normalizeHexColor(textInput.value);
                    if (normalized) {
                        colorInput.value = normalized;
                    }
                });

                textInput.addEventListener('blur', function () {
                    const normalized = normalizeHexColor(textInput.value);
                    textInput.value = normalized || String(colorInput.value || '').toUpperCase();
                });
            });
        });
    </script>
{% endblock %}

<!DOCTYPE html>
<html lang="fr">
<head>
    {% set settings = theme_service.getAll %}
    {% set activeTemplate = settings['active_template']|default('template2') %}
    {% set activeStylesheetVersion = theme_service.getTemplateStylesheetVersion(activeTemplate) %}
    {% set googleFontUrls = theme_service.getGoogleFontStylesheets(settings) %}
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Mot de passe oublie - {{ settings.site_title|default('Dashboard ADEP') }}</title>
    {% if googleFontUrls is not empty %}
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        {% for googleFontUrl in googleFontUrls %}
            <link href="{{ googleFontUrl }}" rel="stylesheet">
        {% endfor %}
    {% endif %}
    <link rel="stylesheet" href="{{ asset(theme_service.getPublishedTemplateStylesheetAssetPath(activeTemplate)) }}?v={{ activeStylesheetVersion }}">
    <style>{{ theme_service.buildCssOverrides(settings)|raw }}</style>
    <style>
        body { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 2rem; }
        .auth-card { width: 100%; max-width: 460px; background: var(--bg-secondary); border: 1px solid var(--border); border-radius: 18px; padding: 2rem; box-shadow: 0 18px 40px var(--shadow-lg); }
    </style>
</head>
<body>
    <form method="post" class="auth-card">
        <h2>Reinitialiser le mot de passe</h2>
        <p class="text-muted">Saisis ton email professionnel pour recevoir un lien securise.</p>

        {% for message in app.flashes('danger') %}
            <div class="alert alert-danger">{{ message }}</div>
        {% endfor %}

        <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" autocomplete="email" required placeholder="collaborateur@entreprise.com">
        </div>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('forgot_password') }}">

        <button class="btn btn-primary btn-block" type="submit">Envoyer le lien</button>

        <div class="auth-link" style="text-align:center; margin-top:1rem;">
            <a href="{{ path('app_login') }}">Retour a la connexion</a>
        </div>
    </form>
</body>
</html>

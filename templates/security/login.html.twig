<!DOCTYPE html>
<html lang="fr">
<head>
    {% set settings = theme_service.getAll %}
    {% set activeTemplate = settings['active_template']|default('template2') %}
    {% set activeStylesheetVersion = theme_service.getTemplateStylesheetVersion(activeTemplate) %}
    {% set googleFontUrls = theme_service.getGoogleFontStylesheets(settings) %}
    {% set bootstrapIconsStylesheet = 'assets/bootstrap-icons/bootstrap-icons.css' %}
    {% set siteTitle = settings.site_title is defined ? settings.site_title|trim : '' %}
    {% set siteTagline = settings.site_tagline is defined ? settings.site_tagline|trim : '' %}
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Connexion - {{ siteTitle != '' ? siteTitle : 'Dashboard ADEP' }}</title>
    {% if googleFontUrls is not empty %}
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        {% for googleFontUrl in googleFontUrls %}
            <link href="{{ googleFontUrl }}" rel="stylesheet">
        {% endfor %}
    {% endif %}
    <link rel="stylesheet" href="{{ asset(theme_service.getPublishedTemplateStylesheetAssetPath(activeTemplate)) }}?v={{ activeStylesheetVersion }}">
    <link rel="stylesheet" href="{{ asset(bootstrapIconsStylesheet) }}">
    <style>{{ theme_service.buildCssOverrides(settings)|raw }}</style>
    <style>
        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }
        .auth-card {
            width: 100%;
            max-width: 460px;
            background: var(--bg-secondary);
            border: 1px solid var(--border);
            border-radius: 18px;
            padding: 2rem;
            box-shadow: 0 18px 40px var(--shadow-lg);
        }
        .auth-brand {
            display: flex;
            align-items: center;
            gap: 0.9rem;
            margin-bottom: 1.5rem;
        }
        .auth-brand.is-logo-only {
            justify-content: center;
            gap: 0;
        }
        .auth-logo {
            width: calc(var(--theme-logo-size, 40px) + 8px);
            height: calc(var(--theme-logo-size, 40px) + 8px);
            border-radius: 16px;
            background: var(--bg-tertiary);
            border: 1px solid var(--border);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            flex: 0 0 auto;
        }
        .auth-logo img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }
        .auth-title {
            margin: 0;
        }
        .auth-subtitle {
            margin: 0.35rem 0 0;
            color: var(--text-muted);
        }
        .auth-link {
            text-align: center;
            margin-top: 1rem;
        }
        .auth-link a {
            text-decoration: none;
        }
    </style>
</head>
<body>
    <form method="post" class="auth-card">
        <div class="auth-brand{% if siteTitle == '' %} is-logo-only{% endif %}">
            <div class="auth-logo">
                {% if settings.logo_path %}
                    <img src="{{ asset(settings.logo_path) }}" alt="Logo du site">
                {% else %}
                    <i class="bi bi-grid-1x2-fill"></i>
                {% endif %}
            </div>
            {% if siteTitle != '' %}
                <div>
                    <h2 class="auth-title">{{ siteTitle }}</h2>
                    <p class="auth-subtitle">{{ siteTagline != '' ? siteTagline : 'Connexion a l espace collaborateur' }}</p>
                </div>
            {% endif %}
        </div>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('danger') %}
            <div class="alert alert-danger">{{ message }}</div>
        {% endfor %}

        {% if error %}
            <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        {% if app.user %}
            <div class="alert alert-info">Vous etes connecte en tant que {{ app.user.userIdentifier }}, <a href="{{ path('app_logout') }}">Se deconnecter</a></div>
        {% endif %}

        <div class="form-group">
            <label for="inputEmail">Email professionnel</label>
            <input type="email" value="{{ last_username }}" name="_username" id="inputEmail" autocomplete="email" required autofocus placeholder="collaborateur@entreprise.com">
        </div>

        <div class="form-group">
            <label for="inputPassword">Mot de passe</label>
            <input type="password" name="_password" id="inputPassword" autocomplete="current-password" required placeholder="********">
        </div>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <button class="btn btn-primary btn-block" type="submit">Se connecter</button>

        <div class="auth-link">
            <a href="{{ path('app_forgot_password') }}">Mot de passe oublie ?</a>
        </div>
    </form>
</body>
</html>

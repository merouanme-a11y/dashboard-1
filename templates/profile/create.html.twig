{% extends 'base.html.twig' %}

{% block title %}Creer un utilisateur{% endblock %}

{% block body %}
{% set pageTitle = page_display_service.resolveNavigationLabel('app_profile_create', 'Creer un utilisateur') %}
{% set formData = formData|default({}) %}
{% set currentService = formData.service|default('') %}
{% set currentDepartement = formData.departement|default('') %}
{% set currentAgence = formData.agence|default('') %}
<div class="profile-container">
    <div class="profile-header">
        <h1 class="page-title-heading">
            {{ page_display_service.renderNavigationIcon('app_profile_create', 'bi-person-plus', 'bootstrap')|raw }}
            <span>{{ pageTitle }}</span>
        </h1>
        <a href="{{ path('app_profile') }}" class="btn btn-secondary">Retour</a>
    </div>

    <div class="profile-card">
        <div class="card-header">
            <h3>Informations du nouvel utilisateur</h3>
        </div>

        <form method="POST" enctype="multipart/form-data">
            <div class="form-row">
                <div class="form-group">
                    <label for="prenom">Prenom *</label>
                    <input type="text" id="prenom" name="prenom" class="form-control" value="{{ formData.prenom|default('') }}" required>
                </div>
                <div class="form-group">
                    <label for="nom">Nom *</label>
                    <input type="text" id="nom" name="nom" class="form-control" value="{{ formData.nom|default('') }}" required>
                </div>
            </div>

            <div class="form-group">
                <label for="email">Email *</label>
                <input type="email" id="email" name="email" class="form-control" value="{{ formData.email|default('') }}" required>
            </div>

            <div class="form-row form-row-three">
                <div class="form-group">
                    <label for="code_postal">Code postal</label>
                    <input type="text" id="code_postal" name="code_postal" class="form-control" value="{{ formData.code_postal|default('') }}">
                    <small id="code_postal_feedback" class="form-feedback"></small>
                </div>
                <div class="form-group">
                    <label for="departement">Departement</label>
                    <select id="departement" name="departement" class="form-control">
                        <option value="">-</option>
                        {% for departement in departementOptions %}
                            <option value="{{ departement }}" {% if currentDepartement == departement %}selected{% endif %}>{{ departement }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="form-group">
                    <label for="agence">Agence</label>
                    <select id="agence" name="agence" class="form-control">
                        <option value="">-</option>
                        {% for option in agenceOptions %}
                            <option value="{{ option.agence }}" data-departement="{{ option.departement }}" {% if currentAgence == option.agence %}selected{% endif %}>
                                {{ option.agence }}{% if option.departement %} - {{ option.departement }}{% endif %}
                            </option>
                        {% endfor %}
                    </select>
                </div>
            </div>

            <div class="form-row form-row-three">
                <div class="form-group">
                    <label for="telephone">Telephone</label>
                    <input type="tel" id="telephone" name="telephone" class="form-control" value="{{ formData.telephone|default('') }}">
                </div>
                <div class="form-group">
                    <label for="numero_court">Numero court</label>
                    <input type="text" id="numero_court" name="numero_court" class="form-control" value="{{ formData.numero_court|default('') }}">
                </div>
                <div class="form-group">
                    <label for="service">Service</label>
                    <select id="service" name="service" class="form-control">
                        <option value="">-</option>
                        {% for service in serviceOptions %}
                            <option value="{{ service }}" {% if currentService == service %}selected{% endif %}>{{ service }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>

            <div class="form-group">
                <label for="profile_type">Profil *</label>
                <select id="profile_type" name="profile_type" class="form-control" required>
                    <option value="Employe" {% if formData.profile_type|default('Employe') == 'Employe' %}selected{% endif %}>Employe</option>
                    <option value="Superviseur" {% if formData.profile_type|default('Employe') == 'Superviseur' %}selected{% endif %}>Superviseur</option>
                    <option value="Responsable" {% if formData.profile_type|default('Employe') == 'Responsable' %}selected{% endif %}>Responsable</option>
                    <option value="Admin" {% if formData.profile_type|default('Employe') == 'Admin' %}selected{% endif %}>Admin</option>
                </select>
            </div>

            <hr>

            <div class="form-group">
                <label for="initial_password">Mot de passe initial *</label>
                <input type="password" id="initial_password" name="initial_password" class="form-control" required>
                <small>Minimum 6 caracteres. L utilisateur devra changer son mot de passe a la premiere connexion.</small>
            </div>

            <div class="form-group">
                <label for="confirm_initial_password">Confirmer le mot de passe *</label>
                <input type="password" id="confirm_initial_password" name="confirm_initial_password" class="form-control" required>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Creer l utilisateur</button>
                <a href="{{ path('app_profile') }}" class="btn btn-secondary">Annuler</a>
            </div>
        </form>
    </div>
</div>

<style>
    .profile-container {
        max-width: 900px;
        margin: 0 auto;
    }

    .profile-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .profile-card {
        border-radius: 12px;
        border: 1px solid var(--border);
        background: var(--bg-primary);
        padding: 2rem;
        box-shadow: 0 2px 8px var(--shadow);
    }

    .card-header {
        margin-bottom: 1.5rem;
    }

    .card-header h3 {
        margin: 0;
        font-size: 1.1rem;
        font-weight: 600;
    }

    .form-group {
        margin-bottom: 1rem;
    }

    .form-group label {
        display: block;
        font-weight: 600;
        font-size: 0.95rem;
        margin-bottom: 0.5rem;
        color: var(--text-primary);
    }

    .form-group small {
        display: block;
        color: var(--text-secondary);
        font-size: 0.85rem;
        margin-top: 0.25rem;
    }

    .form-control {
        width: 100%;
        padding: 0.75rem;
        border: 1px solid var(--border);
        border-radius: 8px;
        font-size: 1rem;
        background: var(--bg-secondary);
        color: var(--text-primary);
    }

    .form-control:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
    }
    .form-feedback {
        display: block;
        min-height: 1rem;
        margin-top: 0.4rem;
        color: var(--text-muted);
        font-size: 0.82rem;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .form-row-three {
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .form-actions {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
    }

    .btn {
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        font-weight: 500;
        cursor: pointer;
        border: none;
        transition: all 0.2s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .btn-primary {
        background: var(--primary);
        color: white;
    }

    .btn-primary:hover {
        background: var(--primary-dark);
    }

    .btn-secondary {
        background: var(--bg-secondary);
        color: var(--text-primary);
        border: 1px solid var(--border);
    }

    .btn-secondary:hover {
        background: var(--bg-tertiary);
    }

    hr {
        margin: 1.5rem 0;
        border: none;
        border-top: 1px solid var(--border);
    }

    @media (max-width: 768px) {
        .profile-header {
            flex-direction: column;
            gap: 1rem;
        }

        .form-row,
        .form-row-three {
            grid-template-columns: 1fr;
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const codePostalInput = document.getElementById('code_postal');
        const codePostalFeedback = document.getElementById('code_postal_feedback');
        const departementSelect = document.getElementById('departement');
        const agenceSelect = document.getElementById('agence');

        if (!codePostalInput || !departementSelect || !agenceSelect) {
            return;
        }

        let lookupTimeout = null;
        let lastLookupPostalCode = '';

        function normalizeValue(value) {
            return String(value || '')
                .normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '')
                .toLowerCase()
                .trim();
        }

        function setFeedback(message, isError) {
            if (!codePostalFeedback) {
                return;
            }

            codePostalFeedback.textContent = message || '';
            codePostalFeedback.style.color = isError ? '#dc2626' : 'var(--text-muted)';
        }

        function syncAgenceOptions(options) {
            const config = options || {};
            const selectedDepartement = normalizeValue(departementSelect.value || '');
            const visibleOptions = [];

            Array.from(agenceSelect.options).forEach(function(option) {
                if (option.value === '') {
                    option.hidden = false;
                    return;
                }

                const optionDepartement = normalizeValue(option.dataset.departement || '');
                const isVisible = selectedDepartement === '' || optionDepartement === selectedDepartement;
                option.hidden = !isVisible;

                if (!isVisible && option.selected) {
                    agenceSelect.value = '';
                }

                if (isVisible) {
                    visibleOptions.push(option);
                }
            });

            if (!config.autoSelect) {
                return visibleOptions;
            }

            if (visibleOptions.length === 0) {
                agenceSelect.value = '';
                return visibleOptions;
            }

            if (visibleOptions.some(function(option) { return option.value === agenceSelect.value; })) {
                return visibleOptions;
            }

            agenceSelect.value = visibleOptions[0].value;

            return visibleOptions;
        }

        function syncDepartementFromAgence() {
            const selectedOption = agenceSelect.options[agenceSelect.selectedIndex];
            if (!selectedOption || selectedOption.value === '') {
                return;
            }

            const optionDepartement = (selectedOption.dataset.departement || '').trim();
            if (optionDepartement !== '') {
                departementSelect.value = ensureDepartementOption(optionDepartement);
            }
        }

        function findDepartementOptionValue(apiDepartement) {
            if (!apiDepartement || !apiDepartement.code || !apiDepartement.nom) {
                return '';
            }

            const expectedCode = normalizeValue(apiDepartement.code);
            const expectedName = normalizeValue(apiDepartement.nom);
            const expectedCombined = normalizeValue(apiDepartement.code + ' - ' + apiDepartement.nom);

            for (const option of Array.from(departementSelect.options)) {
                if (option.value === '') {
                    continue;
                }

                const optionValue = normalizeValue(option.value);
                if (
                    optionValue === expectedCombined
                    || optionValue === expectedCode
                    || optionValue === expectedName
                    || optionValue.startsWith(expectedCode + ' ')
                    || optionValue.startsWith(expectedCode + '-')
                    || optionValue.indexOf(expectedName) !== -1
                ) {
                    return option.value;
                }
            }

            return '';
        }

        function ensureDepartementOption(label) {
            const normalizedLabel = normalizeValue(label);

            for (const option of Array.from(departementSelect.options)) {
                if (option.value !== '' && normalizeValue(option.value) === normalizedLabel) {
                    return option.value;
                }
            }

            const dynamicOption = document.createElement('option');
            dynamicOption.value = String(label || '').trim();
            dynamicOption.textContent = dynamicOption.value;
            dynamicOption.dataset.generated = 'true';
            departementSelect.appendChild(dynamicOption);

            return dynamicOption.value;
        }

        function resolveDepartementValue(apiDepartement) {
            const existingValue = findDepartementOptionValue(apiDepartement);
            if (existingValue !== '') {
                return existingValue;
            }

            if (!apiDepartement || !apiDepartement.code || !apiDepartement.nom) {
                return '';
            }

            return ensureDepartementOption(apiDepartement.code + ' - ' + apiDepartement.nom);
        }

        async function lookupPostalCode() {
            const rawPostalCode = String(codePostalInput.value || '').trim();
            const postalCode = rawPostalCode.replace(/\D/g, '');

            if (postalCode.length === 0) {
                lastLookupPostalCode = '';
                setFeedback('', false);
                return;
            }

            if (postalCode.length !== 5) {
                setFeedback('Saisissez un code postal a 5 chiffres.', true);
                return;
            }

            if (postalCode === lastLookupPostalCode) {
                return;
            }

            setFeedback('Recherche du departement via API Gouv...', false);

            try {
                const response = await fetch('https://geo.api.gouv.fr/communes?codePostal=' + encodeURIComponent(postalCode) + '&fields=nom,departement&boost=population&format=json', {
                    headers: {
                        'Accept': 'application/json',
                    },
                });

                if (!response.ok) {
                    throw new Error('HTTP ' + response.status);
                }

                const communes = await response.json();
                if (!Array.isArray(communes) || communes.length === 0) {
                    throw new Error('not_found');
                }

                const departementValue = resolveDepartementValue(communes[0].departement || null);
                if (departementValue === '') {
                    setFeedback('Departement trouve via API Gouv, mais impossible a renseigner.', true);
                    return;
                }

                departementSelect.value = departementValue;
                const visibleOptions = syncAgenceOptions({ autoSelect: true });
                lastLookupPostalCode = postalCode;

                if (visibleOptions.length === 1) {
                    setFeedback('Departement et agence renseignes automatiquement.', false);
                } else if (visibleOptions.length > 1) {
                    setFeedback('Departement renseigne. Agence preselectionnee a verifier.', false);
                } else {
                    setFeedback('Departement renseigne via API Gouv. Aucune agence locale pour ce departement.', false);
                }
            } catch (error) {
                lastLookupPostalCode = '';
                if (error instanceof Error && error.message === 'not_found') {
                    setFeedback('Aucun resultat trouve pour ce code postal.', true);
                } else {
                    setFeedback('Recherche impossible pour le moment.', true);
                }
            }
        }

        function schedulePostalLookup() {
            window.clearTimeout(lookupTimeout);
            lookupTimeout = window.setTimeout(lookupPostalCode, 350);
        }

        syncDepartementFromAgence();
        syncAgenceOptions();

        agenceSelect.addEventListener('change', function() {
            syncDepartementFromAgence();
            syncAgenceOptions();
        });

        departementSelect.addEventListener('change', syncAgenceOptions);
        codePostalInput.addEventListener('input', schedulePostalLookup);
        codePostalInput.addEventListener('blur', lookupPostalCode);

        if ((codePostalInput.value || '').trim() !== '' && (!departementSelect.value || !agenceSelect.value)) {
            lookupPostalCode();
        }
    });
</script>
{% endblock %}
